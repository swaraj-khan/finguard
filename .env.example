# Copy this file to `.env` and fill in the values.

# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Service role key (server-side only — bypasses Row Level Security). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Anon key (not required by the backend, kept here for reference).
SUPABASE_ANON_KEY=

# Password that protects the upload endpoint (sent in the X-API-Password header).
API_PASSWORD=

# Table that stores uploaded documents.
UPLOAD_DOC_TABLE=upload_doc

# Table that stores the structured analysis of uploaded documents.
ANALYZED_DOC_TABLE=analyzed_doc

# Supabase Storage bucket where the actual files are stored (public).
STORAGE_BUCKET=documents
